---
layout: null
permalink: /knowledge/papers/index.json
---
{
  "schema_version": "0.1",
  "assessment_rubric": {{ site.data.knowledge_axes | jsonify }},
  "contribution_type_vocabulary": {{ site.data.contribution_types | jsonify }},
  "count": {{ site.data.publications | size }},
  "papers": [
    {% assign ordered_papers = site.data.publications | sort: "id" %}
    {% for paper in ordered_papers %}
      {% assign landing_matches = site.papers | where: "paper_id", paper.id %}
      {% assign landing = landing_matches | first %}
      {% assign resource_matches = site.data.publication_resources | where: "id", paper.id %}
      {% assign resources = resource_matches | first %}
      {% capture map_key %}paper_{{ paper.id }}{% endcapture %}
      {% assign mapped_record = site.data.knowledge_maps[map_key] %}
      {
        "id": {{ paper.id | jsonify }},
        "stable_id": {{ paper.id | prepend: "paper-" | jsonify }},
        "url": {{ landing.url | absolute_url | jsonify }},
        "title": {{ paper.title | jsonify }},
        "authors": {{ paper.authors | jsonify }},
        "year": {{ paper.year | jsonify }},
        "status": {{ paper.status | jsonify }},
        "venue": {{ paper.venue | jsonify }},
        "venue_url": {{ paper.venue_url | jsonify }},
        "topic": {{ paper.topic | jsonify }},
        "labels": {{ paper.labels | jsonify }},
        "ai_ml_labels": {{ paper.ai_ml_labels | jsonify }},
        "contribution_types": {{ paper.contribution_types | jsonify }},
        "tags": {{ paper.tags | jsonify }},
        "abstract": {{ paper.abstract | jsonify }},
        "abstract_kind": {{ paper.abstract_kind | jsonify }},
        "abstract_review_status": {{ paper.abstract_review_status | jsonify }},
        "abstract_added_at": {{ paper.abstract_added_at | jsonify }},
        "abstract_note": {{ paper.abstract_note | jsonify }},
        "abstract_source_url": {{ paper.abstract_source_url | jsonify }},
        "summary": {{ paper.summary | jsonify }},
        "availability": {{ paper.availability | jsonify }},
        "resources": {{ resources | jsonify }},
        "knowledge_stage": {% if mapped_record %}{{ mapped_record.stage | jsonify }}{% else %}"discovery"{% endif %},
        "source_scope": {% if mapped_record %}{{ mapped_record.curation.source_scope | default: "unknown" | jsonify }}{% else %}null{% endif %},
        "knowledge_map_url": {% if mapped_record %}{{ mapped_record.machine_path | absolute_url | jsonify }}{% else %}null{% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
